NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_READ_TOKEN=replace-with-read-token
SANITY_REVALIDATE_SECRET=replace-with-revalidate-secret
RESEND_API_KEY=replace-with-resend-api-key

# Site access gate (production only). Set to base64("user:password") to require Basic Auth on every page route.
# Leave blank/unset to disable the gate (site is fully public). Also blacks out robots.txt and sitemap.xml when set.
SITE_AUTH_BASIC=

# Used only by `npm run generate:maps` to call Azure Maps geocoding + static image APIs. Never read at runtime.
AZURE_MAPS_KEY=replace-with-azure-maps-key
